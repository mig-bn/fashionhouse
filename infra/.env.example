# =============================================
# Fashion House Boutique — Variables de entorno
# Copiar a .env y completar los valores reales
# NUNCA commitear el .env con valores reales
# =============================================

# Base de datos
DB_USER=fashionhouse
DB_PASSWORD=changeme_db_password

# JWT
JWT_SECRET=changeme_jwt_secret_must_be_at_least_32_characters_long

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_minio_password

# Next.js
NEXTAUTH_SECRET=changeme_nextauth_secret_32_chars

# Email (opcional en desarrollo)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Redis (futuro)
# REDIS_PASSWORD=changeme_redis_password
